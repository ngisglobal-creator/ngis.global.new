:80 {
    root * /app/public
    php_server
    file_server
    encode zstd gzip
    header {
        # Enable HTTP Strict Transport Security (HSTS)
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    }
    handle_errors {
        @404 expression {err.status_code} == 404
        rewrite @404 /index.php
    }
}
